---
// Prototype version switcher — shared across every home-page direction so we can
// jump between them while comparing. Self-contained styles (scoped) so it can't
// clash with each version's very different CSS.
const { current } = Astro.props;
const versions = [
  { href: '/',   n: 'H', name: 'Home · 4a' },
  { href: '/v1', n: '1', name: 'Billboard' },
  { href: '/v2', n: '2', name: 'Terminal' },
  { href: '/v3', n: '3', name: 'Cover' },
  { href: '/v4', n: '4', name: 'Grid' },
  { href: '/v5', n: '5', name: 'Essay' },
];
const cur = String(current);
---
<nav class="vbar" aria-label="Prototype version switcher">
  <span class="vbar__tag">nmajor.com · prototypes</span>
  <span class="vbar__list">
    {versions.map((v) => (
      <a
        class={`vbar__link${v.n === cur ? ' is-current' : ''}`}
        href={v.href}
        aria-current={v.n === cur ? 'page' : undefined}
      >
        <b>v{v.n}</b><span class="vbar__name"> {v.name}</span>
      </a>
    ))}
  </span>
</nav>

<style>
  .vbar {
    box-sizing: border-box;
    width: 100%;
    display: flex;
    align-items: center;
    gap: 0.5rem 1rem;
    flex-wrap: wrap;
    padding: 0.4rem clamp(0.8rem, 3vw, 1.5rem);
    background: #0a0a0b;
    color: #e9e9e6;
    font-family: ui-monospace, 'SFMono-Regular', Menlo, monospace;
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    line-height: 1.4;
    border-bottom: 1px solid #2a2a2a;
    position: relative;
    z-index: 9999;
  }
  .vbar__tag { color: #7a7a75; text-transform: uppercase; }
  .vbar__list { display: flex; gap: 0.35rem; flex-wrap: wrap; margin-left: auto; }
  .vbar__link {
    color: #cfcfca;
    text-decoration: none;
    padding: 0.18rem 0.55rem;
    border: 1px solid transparent;
    border-radius: 2px;
    white-space: nowrap;
  }
  .vbar__link b { color: #fff; font-weight: 700; }
  .vbar__link:hover { border-color: #444; color: #fff; }
  .vbar__link.is-current { background: #f5f5f0; color: #0a0a0b; border-color: #f5f5f0; }
  .vbar__link.is-current b { color: #0a0a0b; }
  @media (max-width: 520px) {
    .vbar__tag { display: none; }
    .vbar__list { margin-left: 0; }
    .vbar__name { display: none; }
  }
</style>

<style is:global>
  /* v4 ("Loud grid") pads its <body> on all sides; drop just the top pad so the
     switcher sits flush at the very top like it does on every other version. */
  body:has(.frame) { padding-top: 0; }
</style>
