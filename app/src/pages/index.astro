---
// nmajor.com home — direction 4a. Nav/footer/head come from Base; this page owns
// the hero, about, listing blocks, and the subscribe card. Content (essays, takes)
// is pulled from the collections — the home page shows the latest of each.
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { monthYear, readingMinutes, relativeShort } from '../lib/format';
import { isLive } from '../lib/publish.js';

const allEssays = (await getCollection('essays', ({ data }) => isLive(data))).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);
// Hero auto-tracks the newest live essay; `featured: true` is an optional manual
// pin that overrides (used to hold one essay up longer than a week).
const featured = allEssays.find((e) => e.data.featured) ?? allEssays[0];
const latestEssays = allEssays.slice(0, 3);

// isLive (not just !draft): scheduled takes carry a future pubDate and must stay
// hidden until their day; each daily build reveals the ones now due.
const takes = (await getCollection('takes', ({ data }) => isLive(data)))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 5);

const heroMinutes = readingMinutes(featured.body, featured.data.readingMinutes);
const heroMeta = `${heroMinutes} min · ${monthYear(featured.data.pubDate)}`;
---
<Base
  title="Nicholas Major · plain-English AI for people who run things"
  description="Nicholas Major writes honest, hype-free takes on where AI actually fits in a business, and where it doesn't. Fifteen years building software, now helping operators tell the difference."
>
  <!-- ===== HERO (the featured essay) ===== -->
  <section class="hero">
    <div class="eyebrow">This week I'm arguing</div>
    <h1 class="hero__h1">
      {featured.data.heroTitleLead
        ? (<>{featured.data.heroTitleLead}<span class="accent">{featured.data.heroTitleAccent}</span></>)
        : featured.data.title}
    </h1>
    <p class="hero__p">{featured.data.heroLede ?? featured.data.summary}</p>
    <div class="hero__cta">
      <a href={`/writing/${featured.id}/`} class="btn">Read the argument →</a>
      <span class="hero__meta">{heroMeta}</span>
    </div>
  </section>

  <!-- ===== WHO ===== -->
  <section id="about" class="who">
    <div class="who__inner">
      <img class="photo" src="/nicholas-major.jpg" width="112" height="112" alt="Nicholas Major" />
      <p class="who__bio">I'm Nicholas. Fifteen years building software, four years teaching it. Now I help <span class="accent accent--strong">operators</span> work out where AI actually fits, and where it very much doesn't. I write about what I find and think, including the parts I'm unsure about.</p>
    </div>
  </section>

  <!-- ===== ESSAYS ===== -->
  <section id="writing" class="block">
    <div class="block__head">
      <h2 class="block__title">Latest writing</h2>
      <a href="/writing" class="block__all">All writing →</a>
    </div>
    <div class="rows">
      {latestEssays.map((e) => (
        <a href={`/writing/${e.id}/`} class="erow">
          <span class="erow__meta">{monthYear(e.data.pubDate)}<br />{readingMinutes(e.body, e.data.readingMinutes)} min read</span>
          <span class="erow__main">
            <span class="erow__title">{e.data.title}</span>
            <span class="erow__blurb">{e.data.summary}</span>
          </span>
        </a>
      ))}
    </div>
  </section>

  <!-- ===== TAKES ===== -->
  <section id="takes" class="block block--takes">
    <div class="block__head">
      <h2 class="block__title">Latest takes</h2>
      <a href="/takes" class="block__all">All takes →</a>
    </div>
    <div class="rows">
      {takes.map((t) => (
        <div class="trow">
          <span class="trow__text">{t.data.text}</span>
          <span class="trow__when">{relativeShort(t.data.pubDate)}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- ===== SUBSCRIBE ===== -->
  <section id="subscribe" class="sub">
    <div class="sub__card">
      <div class="sub__left">
        <div class="eyebrow">The newsletter</div>
        <div class="sub__namerow">
          <img class="sub__mark" src="/actual-intelligence.svg" width="52" height="52" alt="Actual Intelligence" />
          <h2 class="sub__h2">Actual Intelligence</h2>
        </div>
        <p class="sub__p">Plain-English AI for the people who run things. The actual kind, not the hype. One email a week.</p>
      </div>
      <div class="sub__right">
        <form class="sub__form" id="subForm">
          <input class="sub__input" name="email" type="email" required placeholder="you@company.com" aria-label="Email address" autocomplete="email" />
          <div id="turnstile-home-subscribe" class="cf-turnstile" data-sitekey="0x4AAAAAADwCt8xxNYgYoiEK" data-action="nmajor_subscribe" data-theme="dark" data-size="flexible"></div>
          <button class="sub__btn" type="submit">Subscribe</button>
        </form>
        <p class="sub__msg" id="subMsg" role="status" aria-live="polite"></p>
        <div class="sub__done" id="subDone" hidden>
          <div class="sub__doneTitle">Almost there.</div>
          <div class="sub__doneSub">Check your inbox for a confirmation link.</div>
        </div>
        <div class="sub__count">Unsubscribe in one click. I'll never share your email.</div>
      </div>
    </div>
  </section>

  <style>
    /* hero */
    .hero { max-width: var(--wrap); margin: 0 auto; padding: clamp(56px,9vw,96px) clamp(20px,5vw,48px) clamp(52px,7vw,72px); }
    .hero .eyebrow { display: block; margin-bottom: 24px; }
    .hero__h1 { margin: 0; font-size: clamp(44px,7.6vw,82px); line-height: .95; letter-spacing: -.04em; font-weight: 900; max-width: 15ch; }
    .hero__p { margin: 28px 0 0; max-width: 56ch; font-size: clamp(17px,1.6vw,19px); line-height: 1.55; color: var(--body); }
    .hero__cta { display: flex; align-items: center; gap: 22px; flex-wrap: wrap; margin-top: 36px; }
    .hero__meta { font-family: ui-monospace, monospace; font-size: 12px; color: var(--muted); }

    /* who */
    .who { background: var(--panel); border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); }
    .who__inner { max-width: var(--wrap); margin: 0 auto; padding: clamp(32px,4vw,40px) clamp(20px,5vw,48px); display: flex; gap: clamp(20px,3vw,28px); align-items: center; flex-wrap: wrap; }
    .photo { flex: none; width: 112px; height: 112px; border-radius: 16px; border: 1px solid rgba(229,57,31,.35); object-fit: cover; display: block; }
    .who__bio { margin: 0; font-size: clamp(16px,1.55vw,17.5px); line-height: 1.6; flex: 1; min-width: 280px; color: #3a352e; font-weight: 500; }

    /* subscribe */
    .sub { max-width: var(--wrap); margin: 0 auto; padding: 0 clamp(20px,5vw,48px) clamp(44px,5vw,52px); }
    .sub__card { background: var(--ink); color: var(--paper); border-radius: 24px; padding: clamp(38px,5vw,56px) clamp(28px,4vw,48px); display: flex; gap: 40px; flex-wrap: wrap; align-items: flex-end; justify-content: space-between; }
    .sub__left { flex: 1; min-width: 280px; }
    .sub__left .eyebrow { display: block; margin-bottom: 14px; }
    .sub__namerow { display: flex; align-items: center; gap: 14px; }
    .sub__mark { width: 50px; height: 50px; flex: none; display: block; border-radius: 12px; }
    .sub__h2 { margin: 0; font-size: clamp(28px,3.4vw,38px); font-weight: 900; letter-spacing: -.03em; line-height: 1.02; }
    .sub__p { margin: 16px 0 0; font-size: 16px; line-height: 1.55; color: #a9a396; max-width: 46ch; }
    .sub__right { flex: none; width: min(360px, 100%); }
    .sub__form { display: flex; flex-direction: column; gap: 10px; }
    .sub__form[hidden] { display: none; }
    .sub__input { background: #221f1a; border: 1px solid rgba(255,255,255,.18); border-radius: 11px; padding: 15px 16px; color: var(--paper); font-family: inherit; font-size: 15px; outline: none; }
    .sub__input:focus-visible { border-color: var(--accent); }
    .sub__btn { background: var(--accent); color: #fff; border: none; border-radius: 11px; padding: 15px 26px; font-family: inherit; font-weight: 800; font-size: 15px; cursor: pointer; }
    .sub__btn:hover { opacity: .9; }
    .sub__done { border: 1px solid rgba(229,57,31,.5); border-radius: 11px; padding: 20px; background: rgba(229,57,31,.08); }
    .sub__doneTitle { font-weight: 800; font-size: 16px; color: var(--accent); }
    .sub__doneSub { margin-top: 6px; font-size: 14px; color: #a9a396; }
    .sub__count { margin-top: 14px; font-size: 13px; color: #8f887a; }
    .cf-turnstile { min-height: 1px; }
    .sub__msg { margin: 12px 0 0; font-size: 13.5px; line-height: 1.5; color: #ffb4a8; font-weight: 600; }
    .sub__msg:empty { display: none; }
    .sub__btn:disabled { opacity: .6; cursor: default; }
  </style>

  <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
  <script is:inline>
    // Real subscribe: Turnstile is verified server-side by the Worker's
    // /api/subscribe (worker.js), which then creates the Buttondown subscriber
    // (double opt-in on). The dedicated landing page /subscribe uses the same
    // endpoint. Same sitekey/widget as /subscribe.
    (function () {
      var f = document.getElementById('subForm');
      var msg = document.getElementById('subMsg');
      if (!f) return;
      var btn = f.querySelector('button[type="submit"]');
      var widget = f.querySelector('.cf-turnstile');
      f.addEventListener('submit', async function (e) {
        e.preventDefault();
        msg.className = 'sub__msg';
        msg.textContent = '';
        var email = (f.email.value || '').trim();
        if (!email) { msg.textContent = 'Please enter your email address.'; return; }
        var tokenEl = f.querySelector('[name="cf-turnstile-response"]');
        var token = tokenEl ? tokenEl.value : '';
        if (!token) { msg.textContent = 'Please complete the anti-spam check, then try again.'; return; }
        var label = btn.textContent;
        btn.disabled = true;
        btn.textContent = 'Subscribing...';
        try {
          var res = await fetch('/api/subscribe', {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify({ email: email, 'cf-turnstile-response': token }),
          });
          var data = await res.json();
          if (data.ok) {
            // Rybbit: record the newsletter conversion (new vs already-subscribed).
            if (window.rybbit && window.rybbit.event) {
              window.rybbit.event('newsletter_subscribe', {
                source: 'homepage',
                status: data.already ? 'already' : 'new',
              });
            }
            f.hidden = true;
            document.getElementById('subDone').hidden = false;
            if (data.already) {
              document.querySelector('.sub__doneTitle').textContent = "You're already on the list.";
              document.querySelector('.sub__doneSub').textContent = 'Good to have you.';
            }
          } else {
            msg.textContent = data.error || 'Something went wrong. Please try again.';
            btn.disabled = false;
            btn.textContent = label;
            if (window.turnstile && widget && widget.id) window.turnstile.reset('#' + widget.id);
          }
        } catch (err) {
          msg.textContent = 'Network error. Please try again.';
          btn.disabled = false;
          btn.textContent = label;
          if (window.turnstile && widget && widget.id) window.turnstile.reset('#' + widget.id);
        }
      });
    })();
  </script>
</Base>
