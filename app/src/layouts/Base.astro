---
// Shared shell for every page: <head>, the nav lockup (logo mark + wordmark),
// and the footer. Page content goes in the slot. Keeps the home page and the
// publication pages on one visual system (styles in ../styles/site.css).
import '../styles/site.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
}
const { title, description, ogImage = '/og/default.png' } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://www.nmajor.com');
const ogImageUrl = new URL(ogImage, Astro.site ?? 'https://www.nmajor.com');
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical.href} />
    <meta name="theme-color" content="#faf9f5" />

    <link rel="icon" href="/logo.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/logo.svg" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl.href} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImageUrl.href} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />

    <!-- Rybbit analytics (self-hosted, cookieless). Site id 17. -->
    <script
      is:inline
      src="https://rybbit.nmajor.net/api/script.js"
      data-site-id="17"
      defer></script>
  </head>
  <body>
    <header class="nav">
      <div class="nav__inner">
        <a href="/" class="nav__mark">
          <img class="nav__logo" src="/logo.svg" width="26" height="26" alt="" />
          <span>Nicholas Major</span>
        </a>
        <nav class="nav__links" aria-label="Primary">
          <a href="/writing" class="nlink">Writing</a>
          <a href="/takes" class="nlink">Takes</a>
          <a href="/#about" class="nlink">About</a>
          <a href="/#work" class="nlink nlink--muted">Work with me</a>
          <a href="/subscribe" class="pill">Subscribe</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer id="work" class="foot">
      <div class="foot__inner">
        <div class="foot__top">
          <div class="foot__brand">
            <a href="/" class="foot__mark">
              <img class="foot__marklogo" src="/logo.svg" width="26" height="26" alt="" />Nicholas Major
            </a>
            <div class="foot__cta">
              <span class="foot__ctalabel">Work with me</span>
              <p class="foot__ctatext">I help a few companies implement what I write about.</p>
              <a href="/#work" class="foot__ctalink">How I help <span class="foot__arr" aria-hidden="true">→</span></a>
            </div>
          </div>

          <nav class="foot__cols" aria-label="Footer">
            <div class="foot__col">
              <span class="foot__h">Read</span>
              <a href="/writing">Writing</a>
              <a href="/takes">Takes</a>
              <a href="/building">Building</a>
              <a href="/rss.xml">RSS</a>
            </div>
            <div class="foot__col">
              <span class="foot__h">Related</span>
              <a href="https://appliedartificialintelligence.org" class="foot__org">
                <img class="foot__orglogo" src="/logos/institute.svg" width="18" height="18" alt="" />Institute of Applied AI ↗
              </a>
              <a href="https://executiveaileadership.org" class="foot__org">
                <img class="foot__orglogo" src="/logos/association.svg" width="18" height="18" alt="" />Association for Executive AI Leadership ↗
              </a>
            </div>
            <div class="foot__col">
              <span class="foot__h">Site</span>
              <a href="/#about">About</a>
              <a href="/#work">Work with me</a>
              <a href="/subscribe">Subscribe</a>
              <a href="https://www.linkedin.com/in/nmajor" target="_blank" rel="me noopener">LinkedIn ↗</a>
            </div>
          </nav>
        </div>

        <div class="foot__bottom">
          <span class="foot__meta">© 2026 Nicholas Major · Lisbon</span>
        </div>
      </div>
    </footer>
  </body>
</html>

<style>
  /* nav lockup: logo mark + wordmark */
  .nav__mark { display: inline-flex; align-items: center; gap: 10px; }
  .nav__logo { display: block; border-radius: 6px; flex: none; }
</style>
