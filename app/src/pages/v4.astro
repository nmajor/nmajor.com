---
import '../styles/grid.css';
import VersionBar from '../components/VersionBar.astro';

const takes = [
  "Most 'AI strategy' decks are procurement with extra steps.",
  "If your AI pilot can't survive a real user, it was a demo.",
  "Nobody gets fired for buying the platform. That's the problem.",
  "Your data isn't 'AI-ready.' Nobody's is. Start anyway — smaller.",
  "An agent that needs a human watching it isn't automation. It's an intern.",
];
const filed = [
  { k: 'pilots', v: 'measure escapes, not demos' },
  { k: 'buying', v: 'the safe vendor is the risk' },
  { k: 'data', v: "stop waiting to be 'ready'" },
  { k: 'agents', v: 'an intern with a login' },
];
const writing = [
  { k: 'Jun 26', v: 'The "AI readiness assessment" is a stall tactic' },
  { k: 'May 26', v: 'I rebuilt my whole stack on a $40/mo cluster' },
  { k: 'May 26', v: 'Stop measuring AI pilots by demos' },
];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>NICK MAJOR — positions on shipping AI, no hype</title>
    <meta name="description" content="Nick Major's personal channel: blunt positions on actually shipping AI." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <VersionBar current={4} />
    <div class="frame">
      <div class="gridrow g-3">
        <div class="cell cell--mark">
          <p class="tag">personal channel</p>
          <p class="big">Nick<br />Major<span>.</span></p>
        </div>
        <div class="cell">
          <p class="tag">role</p>
          <p class="big" style="font-size:clamp(1.1rem,3vw,1.6rem)">Engineer who ships AI, not slideware</p>
        </div>
        <div class="cell">
          <p class="tag">est.</p>
          <p class="big" style="font-size:clamp(1.1rem,3vw,1.6rem)">2026<br />nmajor.com</p>
        </div>
      </div>

      <div class="gridrow">
        <div class="cell cell--position">
          <p class="tag">Today's position <span style="color:var(--hot)">●</span></p>
          <p class="position__take" data-take>{takes[0]}</p>
          <div class="position__nav">
            <button class="pbtn" type="button" data-prev>◂ prev</button>
            <button class="pbtn" type="button" data-next>next ▸</button>
            <span class="position__count"><span data-count>01</span> / 05</span>
          </div>
        </div>
      </div>

      <div class="gridrow g-2">
        <div class="cell">
          <p class="tag">Filed under</p>
          <ul class="list">
            {filed.map((f) => (<li><a href="#"><span class="k">{f.k}</span> — {f.v}</a></li>))}
          </ul>
        </div>
        <div class="cell">
          <p class="tag">The writing</p>
          <ul class="list">
            {writing.map((w) => (<li><a href="#"><span class="k">{w.k}</span> · {w.v}</a></li>))}
          </ul>
        </div>
      </div>

      <div class="gridrow">
        <div class="cell cell--sub">
          <p class="tag">Subscribe — the takes, no hype</p>
          <form class="sub" onsubmit="return false">
            <input class="sub__input" type="email" placeholder="you@company.com" aria-label="Email address" required />
            <button class="sub__btn" type="submit">Go</button>
          </form>
        </div>
      </div>
    </div>

    <p class="foot">
      © 2026 Nick Major ·
      <a href="https://appliedartificialintelligence.org">Institute</a> ·
      <a href="https://executiveaileadership.org">Association</a>
    </p>

    <script is:inline define:vars={{ takes }}>
      const el = document.querySelector('[data-take]');
      const c = document.querySelector('[data-count]');
      let i = 0;
      const go = (n) => { i = (i + n + takes.length) % takes.length; el.textContent = takes[i]; c.textContent = String(i + 1).padStart(2, '0'); };
      document.querySelector('[data-next]').addEventListener('click', () => go(1));
      document.querySelector('[data-prev]').addEventListener('click', () => go(-1));
    </script>
  </body>
</html>
