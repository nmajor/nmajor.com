---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { monthYear } from '../../lib/format';

const posts = (await getCollection('building', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
---
<Base
  title="Building · Nicholas Major"
  description="Nicholas Major's build log: home-lab Kubernetes, the systems he actually runs, and whatever he's making now. The engineer behind the AI takes, building in the open."
>
  <header class="phead">
    <div class="eyebrow">Building</div>
    <h1 class="phead__title">Building</h1>
    <p class="phead__sub">Where I build in the open. Home-lab Kubernetes, the systems I actually run, and whatever I'm making now. Rougher than the essays, and added to as I go. The AI takes come from someone who still ships.</p>
  </header>

  <section class="block" style="padding-top: 0;">
    <div class="rows">
      {posts.map((p) => (
        <a href={`/posts/${p.id}/`} class="erow">
          <span class="erow__meta">{monthYear(p.data.date)}</span>
          <span class="erow__main">
            <span class="erow__title">{p.data.title}</span>
            {p.data.description && <span class="erow__blurb">{p.data.description}</span>}
          </span>
        </a>
      ))}
    </div>
  </section>
</Base>
