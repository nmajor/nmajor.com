---
import '../styles/statement.css';
import VersionBar from '../components/VersionBar.astro';

// The thesis rotates through takes; the em-wrapped fragment gets the gold italic.
const theses = [
  { lead: 'Most ', em: '“AI strategy”', tail: ' is procurement with extra steps.' },
  { lead: 'If a pilot can’t survive a real user, it was ', em: 'a demo', tail: '.' },
  { lead: 'The ', em: 'safe', tail: ' vendor choice is the risky one.' },
  { lead: 'Your data was ', em: 'never', tail: ' “AI-ready.” Start anyway — smaller.' },
  { lead: 'An agent you have to watch isn’t automation. It’s ', em: 'an intern', tail: '.' },
];
const essays = [
  { title: 'The “AI readiness assessment” is a stall tactic', date: 'Jun 2026' },
  { title: 'I rebuilt my whole stack on a $40/mo cluster', date: 'May 2026' },
  { title: 'Stop measuring AI pilots by demos', date: 'May 2026' },
];
const t0 = theses[0];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Nick Major — an engineer’s plain read on deploying AI</title>
    <meta name="description" content="Nick Major writes a plain, anti-hype read on actually deploying AI — from an engineer who ships." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;1,9..144,400&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <VersionBar current={5} />
    <div class="wrap">
      <header class="head">
        <span class="head__name">Nick <b>Major</b></span>
        <nav aria-label="Primary">
          <a href="#writing">Writing</a>
          <a href="#about">About</a>
          <a href="#newsletter">Newsletter</a>
        </nav>
      </header>

      <section class="thesis">
        <p class="thesis__eyebrow">The take · <span data-topic>on AI strategy</span></p>
        <h1 class="thesis__body"><span data-lead>{t0.lead}</span><em data-em>{t0.em}</em><span data-tail>{t0.tail}</span></h1>
        <div class="thesis__meta">
          <button class="turn" type="button" data-next>Next take →</button>
          <span><span data-count>1</span> / {theses.length}</span>
        </div>
      </section>

      <section class="byline" id="about">
        <p>I’m <b>Nick Major</b>. I spent a career building and running software before I started helping companies put AI into production — the unglamorous part, where it meets real users, real data, and a real budget.</p>
        <p>I’ve run the infrastructure, not just advised on it. So when I say something’s hype, it’s because I’ve watched it break. This is where I say what I think, plainly.</p>
      </section>

      <section class="section" id="writing">
        <p class="section__label">Latest writing</p>
        <div class="essays">
          {essays.map((e) => (
            <a class="essay" href="#">
              <span class="essay__title">{e.title}</span>
              <span class="essay__date">{e.date}</span>
            </a>
          ))}
        </div>
      </section>

      <section class="section" id="newsletter">
        <div class="news">
          <p class="section__label" style="margin:0">The newsletter</p>
          <h2 class="news__h">The takes, in your inbox — <em>no hype</em>.</h2>
          <form class="news__form" onsubmit="return false">
            <input class="news__input" type="email" placeholder="you@company.com" aria-label="Email address" required />
            <button class="news__btn" type="submit">Subscribe</button>
          </form>
          <p class="news__note">Prototype — not wired up yet.</p>
        </div>
      </section>

      <footer class="foot">
        <span>© 2026 Nick Major · nmajor.com</span>
        <span>
          <a href="https://appliedartificialintelligence.org">Institute</a> ·
          <a href="https://executiveaileadership.org">Association</a>
        </span>
      </footer>
    </div>

    <script is:inline define:vars={{ theses }}>
      const topics = ['on AI strategy', 'on pilots', 'on buying', 'on your data', 'on agents'];
      const leadEl = document.querySelector('[data-lead]');
      const emEl = document.querySelector('[data-em]');
      const tailEl = document.querySelector('[data-tail]');
      const topicEl = document.querySelector('[data-topic]');
      const countEl = document.querySelector('[data-count]');
      let i = 0;
      document.querySelector('[data-next]').addEventListener('click', () => {
        i = (i + 1) % theses.length;
        const t = theses[i];
        leadEl.textContent = t.lead;
        emEl.textContent = t.em;
        tailEl.textContent = t.tail;
        topicEl.textContent = topics[i];
        countEl.textContent = String(i + 1);
      });
    </script>
  </body>
</html>
